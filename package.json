{
  "name": "@aioha/providers",
  "version": "1.9.0-beta.1",
  "description": "Framework-specific providers for Aioha and Magi JS",
  "type": "module",
  "exports": {
    "./lit": {
      "types": "./dist/lit/index.d.ts",
      "import": "./dist/lit/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js"
    },
    "./vue": {
      "types": "./dist/vue/index.d.ts",
      "import": "./dist/vue/index.js",
      "require": "./dist/vue/index.umd.cjs"
    },
    "./svelte": {
      "types": "./dist/svelte/index.d.ts",
      "svelte": "./dist/svelte/index.js"
    },
    "./magi/lit": {
      "types": "./dist/magi/lit/index.d.ts",
      "import": "./dist/magi/lit/index.js"
    },
    "./magi/react": {
      "types": "./dist/magi/react/index.d.ts",
      "import": "./dist/magi/react/index.js"
    },
    "./magi/vue": {
      "types": "./dist/magi/vue/index.d.ts",
      "import": "./dist/magi/vue/index.js",
      "require": "./dist/magi/vue/index.umd.cjs"
    },
    "./magi/svelte": {
      "types": "./dist/magi/svelte/index.d.ts",
      "svelte": "./dist/magi/svelte/index.js"
    }
  },
  "scripts": {
    "build:lit": "cd lit && tsc",
    "build:react": "cd react && tsc",
    "build:vue": "cd vue && vue-tsc && vite build",
    "build:svelte": "cd svelte && vite build && cd ../ && svelte-package --tsconfig svelte/tsconfig.json -i svelte/lib -o dist/svelte -t -p && rm dist/svelte/index.es.js",
    "build:magi:lit": "cd magi/lit && tsc",
    "build:magi:react": "cd magi/react && tsc",
    "build:magi:vue": "cd magi/vue && vue-tsc && vite build",
    "build:magi:svelte": "cd magi/svelte && vite build && cd ../../ && svelte-package --tsconfig magi/svelte/tsconfig.json -i magi/svelte/lib -o dist/magi/svelte -t -p && rm dist/magi/svelte/index.es.js",
    "build:magi": "pnpm run build:magi:lit && pnpm run build:magi:react && pnpm run build:magi:vue && pnpm run build:magi:svelte",
    "build": "pnpm run build:lit && pnpm run build:react && pnpm run build:vue && pnpm run build:svelte && pnpm run build:magi",
    "prepublish": "rm -rf dist/* && pnpm run build",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "aioha",
    "react",
    "vue",
    "hive",
    "blockchain",
    "authentication",
    "web3"
  ],
  "author": "techcoderx",
  "license": "MIT",
  "homepage": "https://aioha.dev",
  "repository": {
    "url": "https://github.com/aioha-hive/providers"
  },
  "bugs": {
    "url": "https://github.com/aioha-hive/providers/issues"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "devDependencies": {
    "@aioha/aioha": "^1.8.2",
    "@aioha/magi": "^0.0.3",
    "@lit/context": "^1.1.6",
    "@sveltejs/package": "^2.5.4",
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "@tanstack/react-query": "^5.94.5",
    "@tanstack/vue-query": "^5.94.5",
    "@tsconfig/svelte": "^5.0.5",
    "@types/node": "^24.6.0",
    "@types/react": "^19.1.8",
    "@vitejs/plugin-vue": "^6.0.1",
    "@wagmi/core": "^3.4.0",
    "@wagmi/vue": "^0.5.0",
    "lit": "^3.3.1",
    "react": "^19.1.0",
    "svelte": "^5.0.0",
    "typescript": "^5.9.2",
    "viem": "^2.47.6",
    "vite": "^7.1.7",
    "vite-plugin-dts": "^4.5.4",
    "vue": "^3.5.22",
    "vue-tsc": "^3.1.0",
    "wagmi": "^3.5.0"
  },
  "peerDependencies": {
    "@aioha/aioha": "^1.8.2",
    "@aioha/magi": "^0.0.3",
    "@lit/context": "^1.1.0",
    "@wagmi/core": "^3.4.0",
    "@wagmi/vue": "^0.5.0",
    "lit": "^3.3.0",
    "react": "^19.1.0",
    "svelte": "^5.0.0",
    "viem": "^2.0.0",
    "vue": "^3.0.0",
    "wagmi": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "@aioha/magi": {
      "optional": true
    },
    "@lit/context": {
      "optional": true
    },
    "@wagmi/core": {
      "optional": true
    },
    "@wagmi/vue": {
      "optional": true
    },
    "lit": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "svelte": {
      "optional": true
    },
    "viem": {
      "optional": true
    },
    "vue": {
      "optional": true
    },
    "wagmi": {
      "optional": true
    }
  }
}
